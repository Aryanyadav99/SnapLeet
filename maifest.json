{
  "manifest_version": 3,
  "name": "SnapLeet",
  "version": "1.0.0",
  "description": "Save LeetCode discussion posts Or Solution with one click.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://leetcode.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "LeetCode Smart Saver",
    "default_popup": "popup.html"
  }
}